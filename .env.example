# TraceScribe — required environment variables
# Copy this file to .env and fill in your values, or export these in your shell profile.
# Values set here are overridden by any matching keys in ~/.tracescribe/config.yaml.

# Jira Data Center base URL (no trailing slash)
JIRA_BASE_URL=https://jsw.ibm.com

# Jira Personal Access Token (generate at: <JIRA_BASE_URL>/secure/ViewProfile.jspa)
JIRA_PAT=

# GitHub personal access token (needs repo + pull_request scopes)
GITHUB_TOKEN=

# Target GitHub repository for Knowledge Center PRs (owner/repo format)
GITHUB_REPO=instana/instana-knowledge-center
